{
  "manifest_version": 3,
  "name": "V-Download",
  "version": "1.1.6",
  "description": "Download videos and detect media streams on any website",
  "permissions": [
    "cookies",
    "contextMenus",
    "storage",
    "activeTab",
    "tabs",
    "alarms",
    "scripting",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://music.youtube.com/*"
      ],
      "js": ["wake-sync.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://127.0.0.1:18765/cookie-sync-landing*"],
      "js": ["content-cookie-sync-landing.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.douyin.com/*",
        "*://douyin.com/*",
        "*://*.iesdouyin.com/*",
        "*://iesdouyin.com/*"
      ],
      "js": ["content-douyin-bridge.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://*.douyin.com/*",
        "*://douyin.com/*",
        "*://*.iesdouyin.com/*",
        "*://iesdouyin.com/*"
      ],
      "js": ["wake-sync.js", "overlay-placement.js", "content-douyin.js"],
      "css": ["content-douyin.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.x.com/*",
        "*://*.twitter.com/*"
      ],
      "js": ["wake-sync.js", "overlay-placement.js", "content-x.js"],
      "css": ["content-x.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.tiktok.com/*",
        "*://tiktok.com/*"
      ],
      "js": ["wake-sync.js", "overlay-placement.js", "content-tiktok.js"],
      "css": ["content-tiktok.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["wake-sync.js", "overlay-placement.js", "media-patterns.js", "content-video-overlay.js"],
      "css": ["content-video-overlay.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content-douyin-bridge.js"],
      "matches": [
        "*://*.douyin.com/*",
        "*://douyin.com/*",
        "*://*.iesdouyin.com/*",
        "*://iesdouyin.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16-gray.png",
      "48": "icons/icon48-gray.png"
    },
    "default_title": "V-Download",
    "default_popup": "popup.html"
  }
}
